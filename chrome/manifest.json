{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.5.8",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "author": "Bayram EREN",
  "homepage_url": "https://github.com/3ayram/",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "eventPage.js"
  },
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "*://*.imdb.com/*",
    "*://www.omdbapi.com/*",
    "*://*.netflix.com/*",
    "*://play.hbomax.com/*",
    "*://*.max.com/*",
    "*://*.primevideo.com/*",
    "*://*.mubi.com/*",
    "*://*.disneyplus.com/*",
    "*://tv.apple.com/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://letterboxd.com/film/*",
        "*://www.letterboxd.com/film/*"
      ],
      "css": [
        "letterboxd.css"
      ],
      "js": [
        "letterboxd.js"
      ]
    },
    {
      "matches": [
        "*://*.imdb.com/title/*",
        "*://*.imdb.com/name/*"
      ],
      "css": [
        "imdb.css"
      ],
      "js": [
        "imdb.js"
      ]
    },
    {
      "matches": [
        "*://*.google.com/search*",
        "*://*.google.com.tr/search*",
        "*://*.google.co.uk/search*",
        "*://*.google.de/search*",
        "*://*.google.es/search*",
        "*://*.google.fr/search*",
        "*://*.google.it/search*"
      ],
      "js": [
        "google.js"
      ]
    },
    {
      "matches": [
        "*://*.netflix.com/*"
      ],
      "js": [
        "netflix.js"
      ]
    },
    {
      "matches": [
        "*://play.hbomax.com/*",
        "*://*.max.com/*"
      ],
      "js": [
        "hbomax.js"
      ]
    },
    {
      "matches": [
        "*://*.primevideo.com/*"
      ],
      "js": [
        "primevideo.js"
      ]
    },
    {
      "matches": [
        "*://*.mubi.com/*"
      ],
      "js": [
        "mubi.js"
      ]
    },
    {
      "matches": [
        "*://*.disneyplus.com/*"
      ],
      "js": [
        "disneyplus.js"
      ]
    },
    {
      "matches": [
        "*://tv.apple.com/*"
      ],
      "js": [
        "apple.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icon16.png",
        "icon32.png"
      ],
      "matches": [
        "*://*.imdb.com/*",
        "*://*.google.com/*",
        "*://*.google.com.tr/*",
        "*://*.google.co.uk/*",
        "*://*.google.de/*",
        "*://*.google.es/*",
        "*://*.google.fr/*",
        "*://*.google.it/*"
      ]
    }
  ]
}